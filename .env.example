# Sepolia RPC endpoint (e.g. Alchemy / Infura)
# Example: https://sepolia.infura.io/v3/YOUR_API_KEY
SEPOLIA_RPC_URL=

# Deployer private key (without 0x prefix is also accepted by Hardhat)
PRIVATE_KEY=

# Optional constructor overrides (defaults match test/EscrowMarketplace.test.js)
# DELIVERY_WINDOW=3600
# CONFIRM_WINDOW=3600
# ARBITER_STAKE_AMOUNT=0.1
# MIN_ACTIVE_ARBITERS=3
# DISPUTE_DEPOSIT=0.001
# DISPUTE_DEPOSIT_WINDOW=3600
# DISPUTE_WINDOW=3600
# SELLER_STAKE_AMOUNT=0.001
# REPORT_DEPOSIT=0.0005
