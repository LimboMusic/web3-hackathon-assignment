{
  "name": "web3-hackathon-assignment",
  "version": "1.0.0",
  "description": "去中心化二手交易担保托管平台。项目场景是校园二手交易，核心目标是用智能合约托管买家资金，避免卖家提前收款、买家单方面退款，并通过多签仲裁和仲裁员保证金处理纠纷。",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test --config hardhat.config.test.js",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:frontend": "npm --prefix frontend run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LimboMusic/web3-hackathon-assignment.git"
  },
